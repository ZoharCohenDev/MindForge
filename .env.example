# Copy this file to .env.local and fill in your values.
# These same variables must be added in Vercel → Project Settings → Environment Variables.

VITE_SUPABASE_URL=your url here, e.g. https://xyzcompany.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# AI generation (used by api/generate-explanation.ts — server-side only, never exposed to the browser)
# Default provider is OpenAI. Set AI_PROVIDER=claude to use Anthropic Claude instead.
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # only needed if AI_PROVIDER=claude
